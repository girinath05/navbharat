<?xml version="1.0" encoding="UTF-8"?>


<!--
    web.xml — ClearPay CTS / NavbharatCTS
    =====================================================================
    Tomcat version: 10.0.27
    Jakarta EE:     Web Profile 5.0  (Tomcat 10.0.x max — NOT 6.0)
    ZK version:     10.0.0-jakarta

    FIXES applied in this version
    ─────────────────────────────────────────────────────────────────────
    FIX 2a — SecurityFilter registered (url-pattern *.zul), ordered first.
    FIX 2b — AccessControlFilter registered (url-pattern *.zul), ordered second.
    FIX 2c — welcome-file changed from "zul/index.zul" to "zul/login.zul"
              so that SecurityUtil.PUBLIC_PATHS (/zul/login.zul) matches.
              index.zul redirects authenticated users to app.zul and
              unauthenticated users to login.zul, so either is safe as
              the welcome-file; login.zul is the canonical public entry.
    FIX 2d — AppContextListener registered to start/stop UserUnlockScheduler.
    =====================================================================
-->

<web-app
    xmlns="https://jakarta.ee/xml/ns/jakartaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        https://jakarta.ee/xml/ns/jakartaee
        https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
    version="6.0">


    <!-- =================================================================
         ZK SESSION LISTENER — declared explicitly so Tomcat finds it even
         when running via Eclipse WTP (Maven classpath JARs not in WEB-INF/lib).
         Must come BEFORE the servlets.
    ================================================================= -->

    <listener>
        <listener-class>
            com.cts.outward.listener.AppStartupListener
        </listener-class>
    </listener>


    <listener>
        <listener-class>
            org.zkoss.zk.ui.http.HttpSessionListener
        </listener-class>
    </listener>

    <!-- FIX 2d: AppContextListener starts/stops UserUnlockScheduler -->
    <listener>
        <listener-class>
            com.cts.AppContextListener
        </listener-class>
    </listener>

    <!-- MERGE: AppStartupListener warms the Hibernate SessionFactory /
         DB connection pool at deploy time (restored from the outward
         module). Independent of AppContextListener above — both run. -->
    <listener>
        <listener-class>
            com.cts.outward.listener.AppStartupListener
        </listener-class>
    </listener>

    <!-- =================================================================
         FIX 2a: SECURITY FILTER — runs first; handles login redirect,
         re-validates user active/locked status on every ZUL request.
    ================================================================= -->

    <filter>
        <filter-name>SecurityFilter</filter-name>
        <filter-class>com.cts.filter.SecurityFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>SecurityFilter</filter-name>
        <url-pattern>*.zul</url-pattern>
    </filter-mapping>

    <!-- =================================================================
         FIX 2b: ACCESS CONTROL FILTER — runs second; enforces per-page
         RBAC permissions after the user has been authenticated.
    ================================================================= -->

    <filter>
        <filter-name>AccessControlFilter</filter-name>
        <filter-class>com.cts.filter.AccessControlFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AccessControlFilter</filter-name>
        <url-pattern>*.zul</url-pattern>
    </filter-mapping>

    <!-- =================================================================
         ZK LAYOUT SERVLET
         Processes *.zul files and renders them as HTML.
         Without this every .zul URL returns 404.
    ================================================================= -->

    <servlet>
        <servlet-name>zkLoader</servlet-name>
        <servlet-class>
            org.zkoss.zk.ui.http.DHtmlLayoutServlet
        </servlet-class>
        <init-param>
            <param-name>update-uri</param-name>
            <param-value>/zkau</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>zkLoader</servlet-name>
        <url-pattern>*.zul</url-pattern>
    </servlet-mapping>


    <!-- =================================================================
         FIX 8: AU SECURITY FILTER — guards /zkau/* so unauthenticated
         or locked users cannot fire ZK AJAX callbacks after session ends.
         Must be declared BEFORE the auEngine servlet mapping.
    ================================================================= -->

    <filter>
        <filter-name>AuSecurityFilter</filter-name>
        <filter-class>com.cts.filter.AuSecurityFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuSecurityFilter</filter-name>
        <url-pattern>/zkau/*</url-pattern>
    </filter-mapping>

    <!-- =================================================================
         ZK AU ENGINE — handles ZK AJAX callbacks (server push, events).
    ================================================================= -->

    <servlet-mapping>
        <servlet-name>zkLoader</servlet-name>
        <url-pattern>/zul/index.zul</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>auEngine</servlet-name>
        <servlet-class>
            org.zkoss.zk.au.http.DHtmlUpdateServlet
        </servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>auEngine</servlet-name>
        <url-pattern>/zkau/*</url-pattern>
    </servlet-mapping>


    <!-- =================================================================
         CHEQUE IMAGE SERVLET — serves cheque front/rear images
    ================================================================= -->

    <servlet>
        <servlet-name>chequeImageServlet</servlet-name>
        <servlet-class>
            com.cts.outward.servlet.ChequeImageServlet
        </servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>chequeImageServlet</servlet-name>
        <url-pattern>/chequeImage</url-pattern>
    </servlet-mapping>

    <!-- =================================================================
         FIX 2c: WELCOME FILE — / loads login.zul (public path).
         Was "zul/index.zul" but SecurityUtil.PUBLIC_PATHS contains
         /zul/login.zul, so the welcome-file must align.
    ================================================================= -->

    <welcome-file-list>
        <welcome-file>zul/login.zul</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>


