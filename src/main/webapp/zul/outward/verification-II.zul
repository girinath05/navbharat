<?xml version="1.0" encoding="UTF-8"?>
<?page title="Verification II — ClearPay CTS"?>

<!--
    verification-II.zul
    Verification-II : High Value & Referred Cheque Authorisation
    Composer : com.cts.outward.composer.Verification2Composer

    Screens:
      Screen 1 — batchListView    : HV batch table
      Screen 2 — chequeListView   : HV/Referred cheques inside selected batch
      Screen 3 — chequeDetailPopup: Full detail overlay — image viewer + data sections + action

    Changes in this version:
      • Popup no longer scrollable — fixed layout, all sections visible without scroll
      • Image viewer: single panel with FRONT / BACK tab toggle (professional, not side-by-side)
      • Data restructured into 3 clear sections: MICR Data | Cheque Data | CBS Data
      • CBS Data section added (UI-only stub for now — backend integration later)
      • Cheque type badge: HIGH VALUE (navy) vs REFERRED (orange) — dynamic from flag
      • Remarks mandatory on Reject; Accept auto-fills "Accepted by <user>"
      • Prev / Next navigation kept; counter centred between them
-->
<zk xmlns="http://www.zkoss.org/2005/zul"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <div id="v2Root" sclass="v2-root"
        apply="com.cts.outward.composer.VerificationIIComposer">

       	 <style src="/css/outward/verification-II.css" />

        <!-- ══════════════════════════════════════════════════════
            PAGE HEADER
            ═══════════════════════════════════════════════════════ -->
        <div sclass="v2-page-header">
            <div sclass="v2-page-title-block">
                <label sclass="v2-page-title" value="Verification II" />
                <label sclass="v2-page-subtitle"
                    value="High Value &amp; Referred Cheque Authorisation" />
            </div>
            <div sclass="v2-hv-badges-row">
                <div sclass="v2-hv-badge-orange">
                    <span sclass="v2-hv-icon">₹</span>
                    <label value="HIGH VALUE" />
                </div>
                <div sclass="v2-hv-badge-blue">
                    <span sclass="v2-hv-icon">⇄</span>
                    <label value="REFERRED" />
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════
            THRESHOLD INFO STRIP
            ═══════════════════════════════════════════════════════ -->
        <div sclass="v2-threshold-strip">
            <span sclass="v2-threshold-icon">⚠</span>
            <label value="Displaying batches containing cheques flagged as High Value or Referred from Verification I" />
            <div sclass="v2-strip-right">
                <label sclass="v2-stat-chip pending-chip"
                    id="totalBatchesChip" value="— Batches" />
                <label sclass="v2-stat-chip hv-chip" id="totalHvChip"
                    value="— HV Cheques" />
                <label sclass="v2-stat-chip ref-chip" id="totalRefChip"
                    value="— Referred" />
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════
            SCREEN 1 — BATCH LIST VIEW
            ═══════════════════════════════════════════════════════ -->
        <div id="batchListView" sclass="v2-card">

            <div sclass="v2-card-header">
                <div sclass="v2-card-header-left">
                    <label sclass="v2-card-title" value="BATCH LIST" />
                </div>
                <div sclass="v2-filter-bar">
                    <textbox id="batchSearchBox" sclass="v2-search-box"
                        placeholder="Search Batch ID..." instant="true" />

                    <div sclass="v2-date-range">
                        <datebox id="batchDateFromBox" sclass="v2-date-box v2-date-from"
                            format="dd-MM-yyyy" placeholder="From" />
                        <label sclass="v2-date-sep" value="→" />
                        <datebox id="batchDateToBox" sclass="v2-date-box v2-date-to"
                            format="dd-MM-yyyy" placeholder="To" />
                    </div>

                    <combobox id="batchStatusCombo" sclass="v2-status-combo" readonly="true">
                        <comboitem label="All"                    value="ALL" />
                        <comboitem label="Ready for Verification" value="PENDING" />
                        <comboitem label="Verified"               value="VERIFIED" />
                        <comboitem label="In Progress"            value="INPROGRESS" />
                    </combobox>

                    <button id="btnClearBatchFilters" sclass="v2-clear-btn" label="✕ Clear" />
                </div>
            </div>

            <grid id="batchGrid" sclass="v2-grid" width="100%">
                <columns sclass="v2-grid-columns">
                    <column label="BATCH ID"          width="9%"  sclass="v2-col-hd" />
                    <column label="DATE"               width="10%" sclass="v2-col-hd v2-center" />
                    <column label="TOTAL CHEQUES"      width="9%"  sclass="v2-col-hd v2-center" />
                    <column label="HV &amp; RF CHEQUES" width="10%" sclass="v2-col-hd v2-center" />
                    <column label="PENDING CHEQUES"    width="9%"  sclass="v2-col-hd v2-center" />
                    <column label="PROCESSED CHEQUES"  width="10%" sclass="v2-col-hd v2-center" />
                    <column label="CHEQUE STATUS"      width="14%" sclass="v2-col-hd v2-center" />
                    <column label="ACTION"             width="9%"  sclass="v2-col-hd v2-center" />
                </columns>
                <rows id="batchRows" />
            </grid>

            <div id="batchEmptyState" sclass="v2-empty-state" visible="false">
                <label sclass="v2-empty-icon" value="📋" />
                <label sclass="v2-empty-msg" value="No batches match the selected filter" />
            </div>

            <div sclass="v2-pagination-bar">
                <label id="batchCountLabel" sclass="v2-page-count-label" value="Showing high-value batches" />
                <div sclass="v2-page-nav">
                    <button id="btnBatchPagePrev" sclass="v2-page-btn" label="‹ Prev" />
                    <label  id="batchPageInfoLabel" sclass="v2-page-info" value="Page 1 of 1" />
                    <button id="btnBatchPageNext" sclass="v2-page-btn" label="Next ›" />
                </div>
            </div>

        </div><!-- /batchListView -->

        <!-- ══════════════════════════════════════════════════════
            SCREEN 2 — HV CHEQUE LIST VIEW
            ═══════════════════════════════════════════════════════ -->
        <!-- chequeListView wrapper -->
        <div id="chequeListView" visible="false">

            <div sclass="v2-card">

            <div sclass="v2-cheque-card-header">

                <!-- Row 1: batch badge | CHEQUE QUEUE | Back to Batches (right end) -->
                <div sclass="v2-cheque-header-row1">
                    <div sclass="v2-cheque-col-left">
                        <label sclass="v2-batch-badge" id="activeBatchLabel" value="" />
                    </div>
                    <div sclass="v2-cheque-col-center">
                        <label sclass="v2-queue-label" value="CHEQUE QUEUE" />
                    </div>
                    <div sclass="v2-cheque-col-right">
                        <button id="btnBackToBatches" sclass="v2-back-btn" label="← Back to Batches" />
                    </div>
                </div>

                <!-- Row 2: search -> date range -> chips -> clear, spread edge-to-edge -->
                <div sclass="v2-cheque-filter-row">
                    <textbox id="chequeSearchBox" sclass="v2-search-box"
                        placeholder="Search cheque no. or payee..." instant="true" />

                    <div sclass="v2-date-range">
                        <datebox id="chequeDateFromBox" sclass="v2-date-box v2-date-from"
                            format="dd-MM-yyyy" placeholder="From" />
                        <label sclass="v2-date-sep" value="→" />
                        <datebox id="chequeDateToBox" sclass="v2-date-box v2-date-to"
                            format="dd-MM-yyyy" placeholder="To" />
                    </div>

                    <div sclass="v2-chip-group">
                        <label id="btnFilterHv"    sclass="v2-stat-chip chip-filter-hv chip-filter"  value="0 High Value" />
                        <label id="btnFilterRef"   sclass="v2-stat-chip chip-filter-ref chip-filter" value="0 Referred" />
                        <span sclass="v2-chip-divider" />
                        <label id="hvPendingChip"  sclass="v2-stat-chip pending-chip chip-filter"    value="0 Pending" />
                        <label id="hvPassedChip"   sclass="v2-stat-chip passed-chip chip-filter"     value="0 Passed" />
                        <label id="hvRejectedChip" sclass="v2-stat-chip rejected-chip chip-filter"   value="0 Rejected" />
                    </div>

                    <button id="btnClearChequeFilters" sclass="v2-clear-btn" label="✕ Clear" />
                </div>

            </div>

            <grid id="chequeGrid" sclass="v2-grid" width="100%">
                <columns sclass="v2-grid-columns">
                    <column label="S.NO."          width="6%"  sclass="v2-col-hd v2-center" />
                    <column label="CHEQUE NO."     width="12%" sclass="v2-col-hd v2-center" />
                    <column label="PAYEE NAME"     width="13%" sclass="v2-col-hd v2-center" />
                    <column label="AMOUNT (Rs.)"   width="16%" sclass="v2-col-hd v2-center" />
                    <column label="DATE"           width="12%" sclass="v2-col-hd v2-center" />
                    <column label="FLAG"           width="8%"  sclass="v2-col-hd v2-center" />
                    <column label="VER STATUS"     width="11%" sclass="v2-col-hd v2-center" />
                    <column label="ACTION"         width="7%"  sclass="v2-col-hd v2-center" />
                </columns>
                <rows id="chequeRows" />
            </grid>

            <div id="chequeEmptyState" sclass="v2-empty-state" visible="false">
                <label sclass="v2-empty-icon" value="✅" />
                <label sclass="v2-empty-msg" value="No cheques match the selected filter" />
            </div>

            <div sclass="v2-pagination-bar">
                <label id="chequeCountLabel" sclass="v2-page-count-label" value="Showing cheques" />
                <div sclass="v2-page-nav">
                    <button id="btnPagePrev"  sclass="v2-page-btn" label="‹ Prev" />
                    <label  id="pageInfoLabel" sclass="v2-page-info" value="Page 1 of 1" />
                    <button id="btnPageNext"  sclass="v2-page-btn" label="Next ›" />
                </div>
            </div>

            </div><!-- /v2-card -->

        </div><!-- /chequeListView -->

        <!-- ══════════════════════════════════════════════════════
            SCREEN 3 — CHEQUE DETAIL POPUP
            Layout: fixed height, NO scroll
              ┌──────────────────────────────────────────────────┐
              │  Title bar                                       │
              ├────────┬─────────────────────────────────────────┤
              │  FRONT │  Cheque Image (full width)              │
              │  ──────│                                         │
              │  BACK  │                                         │
              ├────────┴──────────────┬───────────┬─────────────┤
              │  MICR Data            │ Cheque Data│  CBS Data   │
              ├───────────────────────┴───────────┴─────────────┤
              │ ‹Prev | 2/7 | REMARKS [textbox] | Accept|Reject | Next › │
              └──────────────────────────────────────────────────┘
            ═══════════════════════════════════════════════════════ -->
        <window id="chequeDetailPopup" sclass="v2-popup-window"
            border="none" mode="embedded" closable="false" width="1050px" height="720px">

            <div sclass="v2-popup-shell">

                <!-- ── TITLE BAR ──────────────────────────────── -->
                <div sclass="v2-popup-titlebar">
                    <label sclass="v2-popup-title" id="popupTitle" value="Cheque #——" />
                    <!--
                        popupTypeBadge id is used by composer to swap between
                        v2-badge-hv (dark navy, HIGH VALUE)
                        v2-badge-ref (orange, REFERRED)
                    -->
                    <div id="popupTypeBadge" sclass="v2-badge-hv">HIGH VALUE</div>
                    <button id="btnClosePopup" sclass="v2-close-btn" label="✕" />
                </div>

                <!-- ── TWO-COLUMN BODY ────────────────────────── -->
                <div sclass="v2-popup-body">

                    <!-- LEFT COLUMN — image viewer with single flip button -->
                    <div sclass="v2-img-col">

                        <!-- Front panel -->
                        <div id="imgPanelFront" sclass="v2-img-panel">
                            <div sclass="v2-img-panel-inner">
                                <image id="frontChequeImage" sclass="v2-cheque-img" visible="false" />
                                <div id="frontImagePlaceholder" sclass="v2-img-placeholder">
                                    <label sclass="v2-img-ph-icon" value="🖼" />
                                    <label sclass="v2-img-ph-text" value="Front image not available" />
                                </div>
                            </div>
                        </div>

                        <!-- Back panel (hidden by default) -->
                        <div id="imgPanelBack" sclass="v2-img-panel" visible="false">
                            <div sclass="v2-img-panel-inner">
                                <image id="rearChequeImage" sclass="v2-cheque-img" visible="false" />
                                <div id="rearImagePlaceholder" sclass="v2-img-placeholder">
                                    <label sclass="v2-img-ph-icon" value="🖼" />
                                    <label sclass="v2-img-ph-text" value="Rear image not available" />
                                </div>
                            </div>
                        </div>

                        <!-- Flip button — RIGHT side of image, vertically centred -->
                        <div sclass="v2-flip-btn-col">
                            <button id="btnFlipImage" sclass="v2-flip-btn" label="Show Back" />
                        </div>

                    </div><!-- /img-col -->

                    <!-- RIGHT COLUMN — data sections -->
                    <div sclass="v2-data-col">

                        <!-- ── SECTION 1: MICR DATA ─────────── -->
                        <div sclass="v2-data-section" style="position:relative">
                            <div sclass="v2-data-section-hdr hdr-blue">
                                MICR DATA
                            </div>
                            <div sclass="v2-data-grid-5" >
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="CHEQUE NO." />
                                    <label sclass="v2-field-val" id="fChequeNo" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="CITY CODE" />
                                    <label sclass="v2-field-val" id="fCityCode" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="BANK CODE" />
                                    <label sclass="v2-field-val" id="fBankCode" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="BRANCH CODE" />
                                    <label sclass="v2-field-val" id="fBranchCode" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="TC CODE" />
                                    <label sclass="v2-field-val" id="fTxCode" value="——" />
                                </div>
                            </div>
                        </div>

                        <!-- ── SECTION 2: CHEQUE DATA + CBS DATA (merged) ────────── -->
                        <div sclass="v2-data-section" style="position:relative">
                            <div sclass="v2-data-section-hdr hdr-green">
                                CHEQUE &amp; CBS DATA
                            </div>
                            <div sclass="v2-data-grid-3">
                                <!-- Row 1: PAYEE NAME | PAYEE NAME (CBS) | PAYEE MATCH (CBS) -->
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="PAYEE NAME" />
                                    <label sclass="v2-field-val" id="fPayeeName" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="PAYEE NAME (CBS)" />
                                    <label sclass="v2-field-val v2-cbs-val" id="fCbsPayeeName" value="—" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="PAYEE MATCH (CBS)" />
                                    <label sclass="v2-field-val v2-cbs-val" id="fCbsPayeeMatch" value="—" />
                                </div>
                                <!-- Row 2: CHEQUE DATE | AMOUNT (₹) | AMOUNT IN WORDS -->
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="CHEQUE DATE" />
                                    <label sclass="v2-field-val" id="fChequeDate" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="AMOUNT (₹)" />
                                    <label sclass="v2-field-val v2-amount-val" id="fAmount" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="AMOUNT IN WORDS" />
                                    <label sclass="v2-field-val" id="fAmountWords" value="——" />
                                </div>
                                <!-- Row 3: ACCOUNT NO. | NEW ACCOUNT (CBS) | ACCOUNT STATUS (CBS) -->
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="ACCOUNT NO." />
                                    <label sclass="v2-field-val" id="fAccountNo" value="——" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="NEW ACCOUNT (CBS)" />
                                    <label sclass="v2-field-val v2-cbs-val" id="fCbsNewAccount" value="—" />
                                </div>
                                <div sclass="v2-field-group">
                                    <label sclass="v2-field-lbl" value="ACCOUNT STATUS (CBS)" />
                                    <label sclass="v2-field-val v2-cbs-val" id="fCbsAccStatus" value="—" />
                                </div>
                            </div>
                        </div>

                    </div><!-- /data-col -->
                </div><!-- /popup-body -->

                <!-- ── BOTTOM BAR: single row ────────────────────────── -->
                <!--   ‹ Prev | 1/4 | Next ›  |  REMARKS [box]  Accept  Reject  -->
                <div sclass="v2-action-bar">

                    <!-- Navigation row -->
                    <div sclass="v2-nav-row">
                        <button id="btnPopupPrev" sclass="v2-nav-btn" label="‹ Prev" />
                        <label sclass="v2-popup-counter" id="popupCounter" value="1 / 1" />
                        <button id="btnPopupNext" sclass="v2-nav-btn" label="Next ›" />
                    </div>

                    <!-- Action row -->
                    <div sclass="v2-action-row">
                        <div sclass="v2-remarks-wrap">
                            <textbox id="fVerRemarks" sclass="v2-remarks-box"
                                placeholder="Enter remarks..."
                                multiline="true" rows="1" width="100%" />
                        </div>
                        <div sclass="v2-action-btns">
                            <button id="btnAccept" sclass="v2-accept-btn" label="✔  Accept" />
                            <button id="btnReject" sclass="v2-reject-btn" label="✘  Reject" />
                        </div>
                    </div>

                </div>

            </div><!-- /popup-shell -->
        </window><!-- /chequeDetailPopup -->

    </div><!-- /v2Root -->
</zk>
