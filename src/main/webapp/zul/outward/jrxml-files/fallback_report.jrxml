<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="fallback_report" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <parameter name="ReportTitle" class="java.lang.String"/>
    <parameter name="RecordCount" class="java.lang.Integer"/>

    <title>
        <band height="60">
            <textField>
                <reportElement x="0" y="10" width="535" height="30"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ReportTitle} != null ? $P{ReportTitle} : "Report"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="40" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Total Records: " + ($P{RecordCount} != null ? $P{RecordCount} : 0)]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <noData>
        <band height="40">
            <staticText>
                <reportElement x="0" y="10" width="535" height="20"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[No data available for this report.]]></text>
            </staticText>
        </band>
    </noData>
</jasperReport>
