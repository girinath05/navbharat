<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="batch_summary_report" pageWidth="842" pageHeight="595"
              orientation="Landscape" columnWidth="782" leftMargin="30"
              rightMargin="30" topMargin="20" bottomMargin="20">  
  <!--
      ExpressClear CTS - Batch Summary Report
      Purpose: Displays a summary of multiple batches, including cheque counts, total amounts, creation dates, and status.
    -->
    <parameter name="dateRange" class="java.lang.String"/>
    <parameter name="generatedAt" class="java.lang.String"/>
    <parameter name="totalCountLabel" class="java.lang.String"/>
    <parameter name="totalCountValue" class="java.lang.String"/>
    <parameter name="totalAmount" class="java.lang.String"/>

    <field name="sNo"          class="java.lang.String"/>
    <field name="batchId"      class="java.lang.String"/>
    <field name="totalCheques" class="java.lang.Integer"/>
    <field name="totalAmount"  class="java.math.BigDecimal"/>
    <field name="createdDate"  class="java.time.LocalDateTime"/>
    <field name="status"       class="java.lang.String"/>

    <title>
        <band height="85">
            <textField>
                <reportElement x="0" y="0" width="782" height="25"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["ExpressClear CTS — Batch Summary Report"]]></textFieldExpression>
            </textField>
            
            <!-- Left Column -->
            <textField>
                <reportElement x="0" y="30" width="300" height="15"/>
                <textElement><font size="9" isBold="false"/></textElement>
                <textFieldExpression><![CDATA["Date Range : " + ($P{dateRange} != null ? $P{dateRange} : "")]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="45" width="300" height="15"/>
                <textElement><font size="9" isBold="false"/></textElement>
                <textFieldExpression><![CDATA["Generated : " + ($P{generatedAt} != null ? $P{generatedAt} : "")]]></textFieldExpression>
            </textField>

            <!-- Right Column -->
            <textField>
                <reportElement x="482" y="30" width="300" height="15"/>
                <textElement textAlignment="Right"><font size="9" isBold="false"/></textElement>
                <textFieldExpression><![CDATA[($P{totalCountLabel} != null ? $P{totalCountLabel} : "Total Records") + " : " + ($P{totalCountValue} != null ? $P{totalCountValue} : "0")]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="482" y="45" width="300" height="15"/>
                <textElement textAlignment="Right"><font size="9" isBold="false"/></textElement>
                <textFieldExpression><![CDATA["Total Amount : " + ($P{totalAmount} != null ? $P{totalAmount} : "₹0")]]></textFieldExpression>
            </textField>
            
            <line>
                <reportElement x="0" y="80" width="782" height="1"/>
                <graphicElement><pen lineWidth="1.0" lineColor="#9CA3AF"/></graphicElement>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <!-- S.No -->
            <staticText>
                <reportElement x="0" y="0" width="40" height="24" forecolor="#FFFFFF" backcolor="#1a3a6b" mode="Opaque"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[S.No]]></text>
            </staticText>
            <staticText>
                <reportElement x="40" y="0" width="150" height="24" forecolor="#FFFFFF" backcolor="#1a3a6b" mode="Opaque"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Batch ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="190" y="0" width="120" height="24" forecolor="#FFFFFF" backcolor="#1a3a6b" mode="Opaque"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Total Cheques]]></text>
            </staticText>
            <staticText>
                <reportElement x="310" y="0" width="160" height="24" forecolor="#FFFFFF" backcolor="#1a3a6b" mode="Opaque"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Total Amount]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="0" width="202" height="24" forecolor="#FFFFFF" backcolor="#1a3a6b" mode="Opaque"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Created Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="672" y="0" width="110" height="24" forecolor="#FFFFFF" backcolor="#1a3a6b" mode="Opaque"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <!-- S.No -->
            <textField>
                <reportElement x="0" y="0" width="40" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{sNo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40" y="0" width="150" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{batchId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="190" y="0" width="120" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{totalCheques}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="310" y="0" width="160" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{totalAmount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="470" y="0" width="202" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{createdDate} != null ? $F{createdDate}.format(java.time.format.DateTimeFormatter.ofPattern("dd-MM-yyyy HH:mm")) : ""]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="672" y="0" width="110" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#000000"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{status}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="682" y="0" width="100" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
